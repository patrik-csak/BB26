{
	"extends": "@tsconfig/strictest",
	"include": ["source"],
	"compilerOptions": {
		"rootDir": "source",
		"outDir": "distribution",
		"types": ["node"],
		"declaration": true,
		"incremental": true,
		"stripInternal": true,

		// https://nodejs.org/docs/latest-v24.x/api/typescript.html#type-stripping
		"erasableSyntaxOnly": true,
		"rewriteRelativeImportExtensions": true,
		"verbatimModuleSyntax": true
	}
}
