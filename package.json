{
  "name": "bb26",
  "version": "5.0.2",
  "description": "Bijective base-26 utility library",
  "keywords": [
    "base 26",
    "bijective base 26",
    "spreadsheet",
    "spreadsheet column",
    "spreadsheet column letters",
    "license plate serials"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/patrik-csak/BB26"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./distribution/source/index.d.ts",
      "default": "./distribution/source/index.js"
    }
  },
  "files": [
    "distribution/source"
  ],
  "scripts": {
    "build": "del-cli distribution && tsc",
    "eslint": "eslint --cache",
    "format:check": "npm run prettier -- --check",
    "format:fix": "npm run prettier -- --write",
    "lint:check": "npm run eslint",
    "lint:fix": "npm run eslint -- --fix",
    "prepare": "npm run build",
    "prettier": "prettier --cache .",
    "quality:check": "npm run format:check && npm run lint:check && npm run types:check && npm run unused:check",
    "quality:fix": "npm run format:fix && npm run lint:fix",
    "test": "ava",
    "test:coverage": "del-cli coverage && c8 ava",
    "types:check": "tsc --noEmit",
    "unused:check": "knip"
  },
  "dependencies": {
    "ow": "^3.1.1",
    "random-int": "^3.0.0"
  },
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@sindresorhus/tsconfig": "^8.1.0",
    "ava": "^6.4.1",
    "c8": "^11.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.32.0",
    "eslint-plugin-package-json": "^0.83.0",
    "knip": "^5.86.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "typescript": "^5.0.2",
    "xo": "^1.2.1"
  },
  "engines": {
    "node": ">=20 <=24"
  }
}
