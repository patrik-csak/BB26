{
  "name": "bb26",
  "version": "5.0.2",
  "description": "Bijective base-26 utility library",
  "keywords": [
    "base 26",
    "bijective base 26",
    "spreadsheet",
    "spreadsheet column",
    "spreadsheet column letters",
    "license plate serials"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/patrik-csak/BB26"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./distribution/index.d.ts",
      "default": "./distribution/index.js"
    }
  },
  "files": [
    "distribution"
  ],
  "scripts": {
    "build": "del-cli distribution && tsc",
    "eslint": "eslint --cache",
    "format:check": "npm run prettier -- --check",
    "format:fix": "npm run prettier -- --write",
    "lint:check": "npm run eslint",
    "lint:fix": "npm run eslint -- --fix",
    "prepack": "npm run build",
    "prettier": "prettier --cache .",
    "quality:check": "npm run format:check && npm run lint:check && npm run types:check && npm run unused:check",
    "quality:fix": "npm run format:fix && npm run lint:fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "types:check": "tsc --noEmit",
    "unused:check": "knip"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@vitest/coverage-v8": "^4.1.4",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^5.86.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "xo": "^2.0.2"
  }
}
